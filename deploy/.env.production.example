# Mai production environment. Copy to /opt/mai/.env and fill in.
# NEVER commit the real .env (it is gitignored). setup.sh generates a strong
# SESSION_SECRET automatically if you do not set one.

# Strong random secret. Generate: python -c "import secrets; print(secrets.token_urlsafe(48))"
SESSION_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_STRING

# Keep ON in production (HTTPS terminated by Caddy; uvicorn trusts X-Forwarded-Proto).
COOKIE_SECURE=true

# uvicorn binds localhost only; Caddy is the public entrypoint.
WEB_HOST=127.0.0.1
WEB_PORT=8000
FORWARDED_ALLOW_IPS=127.0.0.1

# SQLite on local disk — sufficient for the maintainer group. Lives at /opt/mai/mai.db.
DATABASE_URL=sqlite+aiosqlite:///./mai.db
GIT_MIRROR_DIR=./mirrors

# Optional — only needed if you run `mai refresh` on the box to pull new commits/PRs.
GITHUB_TOKEN=
REFRESH_INTERVAL_SECONDS=10800
