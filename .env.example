# Mai environment template. Copy to `.env` and fill in the secret keys.
# `.env` is git-ignored; this file is committed as documentation of every var.

# --- Datastore ---
# Local default is SQLite. For production, point at Neon Postgres:
#   DATABASE_URL=postgresql+asyncpg://USER:PASS@HOST/DBNAME
DATABASE_URL=sqlite+aiosqlite:///./mai.db
LEDGER_PATH=./mai-data

# --- GitHub harvester (Plan 02) ---
GITHUB_TOKEN=
GITHUB_API_URL=https://api.github.com

# --- IPS bug-tracker crawler (Plan 03) ---
FIRECRAWL_API_KEY=
FIRECRAWL_API_URL=https://api.firecrawl.dev
IPS_BUG_TRACKER_URL=https://www.getmangos.eu/bug-tracker/

# --- AI enrichment (Plan 04) ---
OPENROUTER_API_KEY=
OPENROUTER_API_URL=https://openrouter.ai/api
ENRICHMENT_MODEL=moonshotai/kimi-k2.5

# --- Embeddings (Plan 05) ---
EMBEDDING_API_KEY=
EMBEDDING_API_URL=https://api.openai.com
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536
